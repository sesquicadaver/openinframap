}
```

Frontend тоді будує `FeatureCollection` з трьома polygon features:

```ts
const collection: FeatureCollection = {
  type: "FeatureCollection",
  features: forecasts.map((forecast) =>
    buildWindStripFeature({
      lon,
      lat,
      bearingToDeg: forecast.bearingToDeg,
      widthKm: 20,
