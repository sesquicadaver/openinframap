## 8. Python-логіка вибору forecast timestamp

Windy повертає `ts` і масиви значень; індекси масивів відповідають timestamp-ам. ([api.windy.com][1])

```python
from datetime import datetime, timedelta, timezone
from math import atan2, degrees, sqrt
from typing import Any

def nearest_forecast_index(timestamps_ms: list[int], lead_hours: int) -> int:
    target = datetime.now(timezone.utc) + timedelta(hours=lead_hours)
    target_ms = int(target.timestamp() * 1000)

    return min(
        range(len(timestamps_ms)),
        key=lambda i: abs(timestamps_ms[i] - target_ms),
    )

def wind_bearing_to_deg(u: float, v: float) -> float:
    return (degrees(atan2(u, v)) + 360) % 360

def build_wind_response(
    payload: dict[str, Any],
    lat: float,
    lon: float,
    model: str,
    lead_hours: int,
) -> dict[str, Any]:
    idx = nearest_forecast_index(payload["ts"], lead_hours)

    u = payload["wind_u-surface"][idx]
    v = payload["wind_v-surface"][idx]
    gust = payload.get("gust-surface", [None])[idx]

    if u is None or v is None:
        raise ValueError("Wind forecast is missing for selected timestamp")

    speed = sqrt(u * u + v * v)
    bearing_to = wind_bearing_to_deg(u, v)

    return {
        "lat": lat,
        "lon": lon,
        "model": model,
        "leadHours": lead_hours,
        "forecastTime": datetime.fromtimestamp(
            payload["ts"][idx] / 1000,
            tz=timezone.utc,
        ).isoformat(),
        "windU": u,
        "windV": v,
        "windSpeedMs": speed,
        "windGustMs": gust,
        "bearingToDeg": bearing_to,
        "bearingFromDeg": (bearing_to + 180) % 360,
    }
```

