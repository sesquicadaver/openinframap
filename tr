## 6. Оновлення шару при русі курсора

API-запити не можна робити на кожен pixel mousemove. Потрібно:

```text
mousemove → debounce 250–500 ms
координати → округлення до 0.01°
запит → backend cache
відповідь → setData()
```

Windy Point Forecast сам округлює координати до 2 знаків після коми, тобто приблизно до 1 км, тому кешувати точніше ніж `0.01°` немає сенсу. ([api.windy.com][1])

```ts
let abortController: AbortController | null = null;

function roundCoord(value: number): number {
  return Math.round(value * 100) / 100;
}

async function updateWindStrip(
  map: maplibregl.Map,
  lngLat: maplibregl.LngLat,
  leadHours: 24 | 48 | 72,
): Promise<void> {
  abortController?.abort();
  abortController = new AbortController();

  const lon = roundCoord(lngLat.lng);
  const lat = roundCoord(lngLat.lat);

  const response = await fetch(
    `/api/weather/wind-strip?lat=${lat}&lon=${lon}&leadHours=${leadHours}`,
    { signal: abortController.signal },
  );

  if (!response.ok) {
    throw new Error(`Wind forecast request failed: ${response.status}`);
  }

  const forecast = await response.json();

  const feature = buildWindStripFeature({
    lon,
    lat,
    bearingToDeg: forecast.bearingToDeg,
    widthKm: 20,
    lengthKm: 120,
    leadHours,
    windSpeedMs: forecast.windSpeedMs,
    windGustMs: forecast.windGustMs,
    forecastTime: forecast.forecastTime,
  });

  const collection: FeatureCollection = {
    type: "FeatureCollection",
    features: [feature],
  };

  const source = map.getSource(WIND_STRIP_SOURCE_ID) as maplibregl.GeoJSONSource;
  source.setData(collection);
}
```

Підключення:

```ts
const debouncedUpdate = debounce((event: maplibregl.MapMouseEvent) => {
  void updateWindStrip(map, event.lngLat, selectedLeadHours);
}, 300);

map.on("mousemove", debouncedUpdate);
```

