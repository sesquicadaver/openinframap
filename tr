## 5. Побудова смуги

Найпростіше — додати залежність Turf:

```bash
cd web
npm install @turf/turf
```

Функція:

```ts
import * as turf from "@turf/turf";
import type { Feature, FeatureCollection, Polygon } from "geojson";

type WindStripInput = {
  lon: number;
  lat: number;
  bearingToDeg: number;
  widthKm: number;
  lengthKm: number;
  leadHours: 24 | 48 | 72;
  windSpeedMs: number;
  windGustMs?: number;
  forecastTime: string;
};

export function buildWindStripFeature(input: WindStripInput): Feature<Polygon> {
  const center = turf.point([input.lon, input.lat]);

  const start = turf.destination(
    center,
    input.lengthKm / 2,
    (input.bearingToDeg + 180) % 360,
    { units: "kilometers" },
  );

  const end = turf.destination(
    center,
    input.lengthKm / 2,
    input.bearingToDeg,
    { units: "kilometers" },
  );

  const centerLine = turf.lineString([
    start.geometry.coordinates,
    end.geometry.coordinates,
  ]);

  const buffered = turf.buffer(centerLine, input.widthKm / 2, {
    units: "kilometers",
  });

  if (!buffered || buffered.geometry.type !== "Polygon") {
    throw new Error("Failed to build wind strip polygon");
  }

  return {
    type: "Feature",
    geometry: buffered.geometry,
    properties: {
      leadHours: input.leadHours,
      bearingToDeg: input.bearingToDeg,
      windSpeedMs: input.windSpeedMs,
      windGustMs: input.windGustMs ?? null,
      forecastTime: input.forecastTime,
    },
  };
}
```

